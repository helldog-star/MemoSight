{
    "template": {
        "model": "llama",
        "prefix": "<|start_header_id|>system<|end_header_id|>\n",
        "middle": "<|eot_id|><|start_header_id|>user<|end_header_id|>\n",
        "suffix": "<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n",
        "complete": "<|start_header_id|>system<|end_header_id|>\n{system}<|eot_id|><|start_header_id|>user<|end_header_id|>\n{question}<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n"
    },
    "prompt": {
        "save_template": true,
        "level": "sentence",
        "step": 1,
        "n_token": 9,
        "token_name": "<|o_{t_id}|>",
        "token_desp": "compress output {t_id}"
    },
    "output": {
        "level": "sentence",
        "step":1 ,
        "n_token": 9,
        "token_name": "<|o_{t_id}|>",
        "token_desp": "compress output {t_id}",
        "meta_compress_step": 1,
        "compression_ratio": -1,
        "forzen_model_train_mtp": false,
        "share_compression_token": false
    }
}